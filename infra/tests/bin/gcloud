#!/usr/bin/env bash
# Mock gcloud for bootstrap.sh tests.
# Logs all invocations to $MOCK_GCLOUD_LOG (one line per call, %q-quoted args).
# Exit code per subcommand controlled by env vars (default 0):
#   MOCK_GCLOUD_DESCRIBE_EXIT  — `gcloud projects describe`
#   MOCK_GCLOUD_CREATE_EXIT    — `gcloud projects create`
#   MOCK_GCLOUD_ENABLE_EXIT    — `gcloud services enable`
#   MOCK_GCLOUD_BILLING_EXIT   — `gcloud billing projects link`

{ printf '%q ' "$@"; printf '\n'; } >> "${MOCK_GCLOUD_LOG:-/dev/null}"

case "$1 $2" in
  "projects describe")  exit "${MOCK_GCLOUD_DESCRIBE_EXIT:-0}" ;;
  "projects create")    exit "${MOCK_GCLOUD_CREATE_EXIT:-0}" ;;
  "services enable")    exit "${MOCK_GCLOUD_ENABLE_EXIT:-0}" ;;
  "billing projects")   exit "${MOCK_GCLOUD_BILLING_EXIT:-0}" ;;
  *)                    exit 0 ;;
esac
